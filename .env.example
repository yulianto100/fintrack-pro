# ╔════════════════════════════════════════════════════════════╗
# ║  Finuvo — Environment Variables Template                  ║
# ║  Copy file ini jadi .env.local lalu isi semua nilai        ║
# ╚════════════════════════════════════════════════════════════╝

# ── 1. NextAuth ────────────────────────────────────────────────
# URL aplikasi saat dev (jangan ubah untuk lokal)
NEXTAUTH_URL=http://localhost:3000
# Generate dengan:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=ganti-dengan-hasil-generate

# ── 2. Google OAuth (OPSIONAL untuk login Google) ─────────────
# Boleh dikosongin kalau cuma mau pakai login email+password.
# Ambil dari: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 3. Firebase Web (Client) — WAJIB ───────────────────────────
# Firebase Console → Project Settings → General → Your apps → Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 4. Firebase Admin (Server) — WAJIB ─────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Buka file JSON yang didownload, copy nilai-nilai berikut:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# PENTING: bungkus dengan tanda kutip ganda. Newline biarkan literal \n (tanpa diconvert).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...isi panjang...==\n-----END PRIVATE KEY-----\n"

# ── 5. Push Notifications (OPSIONAL) ───────────────────────────
# Generate dengan:  npx web-push generate-vapid-keys
# Boleh dikosongin, push notif tetap optional fitur.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@finuvo.local

# ── 6. SMTP / Email OTP (OPSIONAL) ─────────────────────────────
# Untuk register/forgot password via email OTP.
# Pakai Gmail: aktifkan 2FA dulu lalu buat App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── 7. Cron Secret (OPSIONAL di lokal) ─────────────────────────
# Cuma dipakai endpoint /api/cron/* (deposito jatuh tempo, dst).
# Generate dengan:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_SECRET=

# ── 8. Stock API fallback (OPSIONAL) ───────────────────────────
# Daftar gratis di alphavantage.co/support/#api-key (500 req/hari).
# Tanpa ini saham masih jalan via Yahoo Finance scrape.
ALPHA_VANTAGE_API_KEY=
