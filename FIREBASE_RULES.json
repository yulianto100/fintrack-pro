{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "profile": {
          ".indexOn": ["email"]
        },
        "auth": {
          ".indexOn": ["email", "username"]
        },
        "transactions": {
          ".indexOn": [".value"]
        }
      }
    }
  }
}
