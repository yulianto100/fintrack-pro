# ╔════════════════════════════════════════════════════════════╗
# ║  .env.local untuk DEV LOKAL — siap pakai                   ║
# ║  Tinggal isi 3 blok WAJIB di bawah, sisanya udah di-generate
# ╚════════════════════════════════════════════════════════════╝
#
# Cara pakai:
#   1. Rename file ini jadi .env.local (hilangin .template)
#   2. Isi blok 3 + 4 (Firebase) sesuai project Firebase kamu
#   3. (opsional) isi blok 2 kalau mau pakai login Google
#   4. Jalanin: npm run dev
#
# Nilai NEXTAUTH_SECRET dan CRON_SECRET di bawah ini sudah di-generate
# acak khusus untuk install ini. Aman dipakai di lokal, tapi GANTI
# kalau mau push ke production.

# ── 1. NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=EBd4fxXxCY8HRw14CE+CdaH8c+z00PEDZxK2W8WOvfQ=

# ── 2. Google OAuth (kosongin kalau gak pakai) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 3. Firebase Web (Client) — ISI INI ─────────────────────────
# Firebase Console → ⚙️ Project Settings → General → Your apps → Web App → "Config"
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── 4. Firebase Admin (Server) — ISI INI ───────────────────────
# Buka file service-account JSON yang didownload, copy 3 nilai ini:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── 5. Push Notif (boleh skip di lokal) ────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@finuvo.local

# ── 6. SMTP (boleh skip di lokal) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── 7. Cron Secret ─────────────────────────────────────────────
CRON_SECRET=kTDkivjoJpI59gqcsXCk5m52tDyiUECu

# ── 8. Stock API fallback (opsional) ───────────────────────────
ALPHA_VANTAGE_API_KEY=
